# Copy this file to ".env" in the same folder and fill in your real values.
# Never commit the real ".env" file to git or share it publicly.

# Get this from @BotFather on Telegram after creating your bot
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceThisWithYourOwn

# Your personal chat ID (or a group/channel ID) to receive notifications.
# The easiest way to get it: message your bot, then open
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates in a browser
# and look for "chat":{"id": ...}
TELEGRAM_CHAT_ID=123456789

# Port the notification server runs on
PORT=3001
